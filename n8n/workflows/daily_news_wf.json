        {
            "parameters": {
                "jsCode": "const raw = $('AI Summarizer (OpenRouter)').first().json;\nconst summary = raw?.choices?.[0]?.message?.content || 'Không thể tạo bản tóm tắt.';\nconst date = $('Aggregate All Data').first().json.date;\nconst header = `📰 *Bản tin hằng ngày — ${date}*\\n${'─'.repeat(35)}\\n\\n`;\nconst footer = `\\n\\n${'─'.repeat(35)}\\n_Tự động bởi n8n · Mỗi ngày lúc 07:30 GMT+7_`;\nreturn [{ json: { message: header + summary + footer } }];"
            },
